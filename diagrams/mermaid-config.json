  "sequence": {
    "useMaxWidth": false,
    "actorFontFamily": "Segoe UI, -apple-system, sans-serif",
    "actorFontSize": 14,
    "noteFontFamily": "Segoe UI, -apple-system, sans-serif",
    "noteFontSize": 12,
    "messageFontFamily": "Segoe UI, -apple-system, sans-serif",
    "messageFontSize": 13
