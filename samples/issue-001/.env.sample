# Environment Variables — Issue #001 PDF Agent
# These are auto-populated by `azd up`. Only edit for local development.

# Azure subscription and tenant
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_LOCATION=eastus2

# Azure AI Search (auto-provisioned by Bicep)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=pdf-documents

# Azure OpenAI (auto-provisioned by Bicep)
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Azure Blob Storage (auto-provisioned by Bicep)
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_KEY=your-storage-key
PDF_CONTAINER=pdfs

# Teams manifest (replace after publishing)
# TEAMS_APP_ID=auto-generated-during-publish
