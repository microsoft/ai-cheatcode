# Environment Variables — Issue #001 PDF Agent

# Azure subscription and tenant
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_LOCATION=eastus2

# M365 / SharePoint configuration
M365_TENANT_ID=your-m365-tenant-id-here
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/your-site

# Azure OpenAI (provisioned by Bicep, but you can override)
# AZURE_OPENAI_ENDPOINT=https://your-openai-instance.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Teams manifest
TEAMS_APP_ID=auto-generated-during-azd-up
